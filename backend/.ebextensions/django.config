option_settings:
  aws:elasticbeanstalk:container:python:
    WSGIPath: backend.wsgi:application
  aws:elasticbeanstalk:environment:proxy:staticfiles:
    /static: staticfiles
  aws:ec2:instances:
    SupportedArchitectures: x86_64

container_commands:
  01_collectstatic:
    command: "python manage.py collectstatic --noinput"
  02_migrate:
    command: "python manage.py migrate --noinput"
    leader_only: true
  03_superuser:
    command: "python manage.py shell -c \"import os; from django.contrib.auth import get_user_model; User = get_user_model(); u = os.environ.get('DJANGO_SUPERUSER_USERNAME'); p = os.environ.get('DJANGO_SUPERUSER_PASSWORD'); e = os.environ.get('DJANGO_SUPERUSER_EMAIL', ''); User.objects.filter(username=u).exists() or User.objects.create_superuser(u, e, p) if u and p else None\""
    leader_only: true